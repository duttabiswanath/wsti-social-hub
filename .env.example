# ── Gemini AI ──────────────────────────────────────────────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Text model — gemini-2.5-pro is the latest stable model (recommended)
# Alternatives: gemini-2.0-flash (faster/cheaper), gemini-1.5-pro (older)
GEMINI_MODEL=gemini-2.5-pro

# Image generation model — "Nano Banana" (Google's codename for native Gemini image generation)
# Uses the same Gemini API key and generateContent endpoint — no extra setup needed
# Options:
#   gemini-3.1-flash-image-preview  → latest, fast, recommended ✓
#   gemini-3-pro-image-preview      → higher quality, professional assets
#   gemini-2.5-flash-image          → high-volume / low-latency
IMAGEN_MODEL=gemini-3.1-flash-image-preview

# ── Blotato ───────────────────────────────────────────────────────────────────
# Get your API key from: https://my.blotato.com → Settings → API Keys
BLOTATO_API_KEY=your_blotato_api_key_here

# Blotato Account IDs for each platform (find these in your Blotato account)
# These are loaded once in the dashboard Settings panel
BLOTATO_LINKEDIN_ACCOUNT_ID=
BLOTATO_INSTAGRAM_ACCOUNT_ID=
BLOTATO_FACEBOOK_ACCOUNT_ID=
BLOTATO_FACEBOOK_PAGE_ID=
BLOTATO_TWITTER_ACCOUNT_ID=

# ── Google Drive ──────────────────────────────────────────────────────────────
# The Google Drive folder ID where uploaded media will be stored
# e.g. from https://drive.google.com/drive/folders/THIS_PART
GOOGLE_DRIVE_FOLDER_ID=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
